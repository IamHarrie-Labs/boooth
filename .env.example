# Wallet used to deploy contracts and run the agent (must hold tBOT from the faucet)
PRIVATE_KEY=

# Filled in automatically by scripts/deploy.js after deployment
REGISTRY_ADDRESS=
PAYPERCALL_ADDRESS=

# Wallet the device script uses to receive payments (can be the same key or a different one)
DEVICE_PRIVATE_KEY=
DEVICE_ADDRESS=

# Optional: lets the agent reason over readings with an LLM instead of a fixed
# threshold rule. Set either key below, or leave both blank to run the
# fallback rule (no API costs). If both are set, GROQ_API_KEY takes priority.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# A list of provider endpoints the agent checks each tick, separated by commas.
DEVICE_URLS=http://localhost:4000/reading,http://localhost:4001/reading
